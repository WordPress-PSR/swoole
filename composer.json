{
  "name": "wordpress-psr/swoole",
  "description": "WordPress running on the High performance HTTP server based on Swoole.",
  "license": "GPL-3.0-or-later",
  "type": "project",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "authors": [
    {
      "name": "David Stone",
      "email": "david@stonefamily.ro"
    }
  ],
  "require": {
    "php": "^8.2",
    "wordpress-psr/request-handler": "dev-master",
    "chubbyphp/chubbyphp-swoole-request-handler": "^1.5",
    "nyholm/psr7": "^1.4.0",
    "johnpbloch/wordpress-core-installer": "^2.0",
    "johnpbloch/wordpress": "^6.0"
  },
  "require-dev": {
    "roave/security-advisories": "dev-master",
    "swoole/ide-helper": "^6.0",
    "mezzio/mezzio-swoole": "^4.11",
    "rector/rector": "^2.0"
  },
  "provide": {
    "ext-swoole": "6.1.3"
  },
  "config": {
    "allow-plugins": {
      "johnpbloch/wordpress-core-installer": true
    },
    "platform": {
      "php": "8.2.0"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@rector-transform"
    ],
    "post-update-cmd": [
      "@rector-transform"
    ],
    "rector-transform": [
      "Composer\\Config::disableProcessTimeout",
      "rector process --config rector.php --no-progress-bar --no-diffs"
    ]
  }
}
